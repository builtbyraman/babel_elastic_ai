# Sigma UI API — environment configuration
# Copy to .env and adjust for your environment.

# Elasticsearch connection
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

# Path to the sigma_ai project root (where server/translation_script/ lives).
# Docker default: /app/sigma_ai  (matches the volume mount in docker-compose.yml)
# Local dev: set to the absolute path of the repo, e.g. /Users/you/sigma_ai
PLUGIN_ROOT=/app/sigma_ai

# Auth — set to false when Kibana is the only caller and network isolation is sufficient.
# In production with external access, keep true and pass a real Elastic API key as Bearer.
REQUIRE_AUTH=false

# Timeouts (seconds)
CONVERSION_TIMEOUT_SECONDS=30
TEST_RUN_TIMEOUT_SECONDS=60

# Logging
LOG_LEVEL=INFO
DEBUG=false

# AI features (Tier 2) — required for rule drafting, explain, improve, alert → SIGMA
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
