# MCP example environment
MCP_API_BACKEND=http://host.docker.internal:8000/v1
CELERY_BROKER_URL=redis://redis:6379/0
RESULT_BACKEND=redis://redis:6379/1
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mcpdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mcpdb
API_HOST=0.0.0.0
API_PORT=8000

# ── Auth & Encryption ─────────────────────────────────────────────────────────
# AES-GCM key for secrets encryption (base64-encoded 32 bytes).
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SECRETS_KEY=

# Bootstrap tenant — created on first startup (idempotent).
# If BOOTSTRAP_API_KEY is left blank, a key is auto-generated and printed to API logs once.
BOOTSTRAP_TENANT=default
BOOTSTRAP_EMAIL=admin@example.com
BOOTSTRAP_API_KEY=
